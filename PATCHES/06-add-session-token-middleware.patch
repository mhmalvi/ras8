+/**
+ * Example API endpoint with session token validation
+ * Use this pattern for all API endpoints that need Shopify authentication
+ */
+
+import { serve } from "https://deno.land/std@0.190.0/http/server.ts";
+import { createClient } from "https://cdn.skypack.dev/@supabase/supabase-js@2.45.0?dts";
+
+// Import session validation (you'll need to adapt this for Deno)
+import { sessionTokenMiddleware } from '../shared/sessionTokenMiddleware.ts';
+
+const supabaseUrl = Deno.env.get('SUPABASE_URL')!;
+const supabaseServiceKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')!;
+const shopifyClientSecret = Deno.env.get('SHOPIFY_CLIENT_SECRET')!;
+
+const corsHeaders = {
+  'Access-Control-Allow-Origin': '*',
+  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
+};
+
+serve(async (req) => {
+  if (req.method === 'OPTIONS') {
+    return new Response(null, { headers: corsHeaders });
+  }
+
+  try {
+    // Validate session token
+    const sessionMiddleware = sessionTokenMiddleware(shopifyClientSecret);
+    const { session, error } = await sessionMiddleware(req);
+    
+    if (!session) {
+      return new Response(JSON.stringify({ 
+        error: 'Authentication required', 
+        details: error 
+      }), {
+        status: 401,
+        headers: {
+          ...corsHeaders,
+          'Content-Type': 'application/json'
+        }
+      });
+    }
+
+    // Get merchant record based on session shop
+    const supabase = createClient(supabaseUrl, supabaseServiceKey);
+    
+    const { data: merchant } = await supabase
+      .from('merchants')
+      .select('id, shop_domain, settings')
+      .eq('shop_domain', session.shop)
+      .single();
+      
+    if (!merchant) {
+      return new Response(JSON.stringify({ 
+        error: 'Merchant not found' 
+      }), {
+        status: 404,
+        headers: {
+          ...corsHeaders,
+          'Content-Type': 'application/json'
+        }
+      });
+    }
+
+    // Your API logic here - merchant is authenticated and validated
+    return new Response(JSON.stringify({
+      success: true,
+      merchant_id: merchant.id,
+      shop: session.shop,
+      user_id: session.userId
+    }), {
+      headers: {
+        ...corsHeaders,
+        'Content-Type': 'application/json'
+      }
+    });
+
+  } catch (error) {
+    console.error('API error:', error);
+    return new Response(JSON.stringify({ 
+      error: 'Internal server error' 
+    }), {
+      status: 500,
+      headers: {
+        ...corsHeaders,
+        'Content-Type': 'application/json'
+      }
+    });
+  }
+});